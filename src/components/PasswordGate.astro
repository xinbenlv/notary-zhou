---
import { siteConfig } from '../config';
---

{siteConfig.isDraft && (
  <div id="password-gate" class="password-gate">
    <div class="gate-card">
      <div class="gate-logo">
        Notary Zhou <span class="logo-dot"></span>
      </div>
      <h2>Preview Access</h2>
      <p>This site is under development. Enter the preview code to continue.</p>
      <p class="gate-zh">本网站正在建设中。请输入预览密码继续访问。</p>
      <form id="gate-form" class="gate-form">
        <input
          type="password"
          id="gate-input"
          placeholder="Enter preview code"
          autocomplete="off"
          autofocus
        />
        <button type="submit" class="btn btn-green" style="padding: 14px 32px;">
          Enter 进入
        </button>
      </form>
      <p id="gate-error" class="gate-error" style="display: none;">
        Incorrect code. Please try again.
      </p>
    </div>
  </div>

  <style>
    .password-gate {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background-color: var(--bg-cream);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-main);
    }
    .password-gate.hidden {
      display: none;
    }
    .gate-card {
      background: var(--bg-white);
      border-radius: var(--radius-xl);
      padding: 64px;
      max-width: 480px;
      width: 90%;
      text-align: center;
      border: 1px solid var(--border-soft);
      box-shadow: 0 20px 60px rgba(0,0,0,0.04);
    }
    .gate-logo {
      font-size: 24px;
      font-weight: 700;
      color: var(--brand-green);
      margin-bottom: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }
    .gate-logo .logo-dot {
      width: 8px;
      height: 8px;
      background-color: var(--brand-terra);
      border-radius: 50%;
      display: inline-block;
    }
    .gate-card h2 {
      font-size: 28px;
      color: var(--brand-green);
      margin-bottom: 12px;
    }
    .gate-card p {
      color: var(--text-muted);
      font-size: 15px;
      margin-bottom: 8px;
    }
    .gate-zh {
      font-size: 14px !important;
      margin-bottom: 32px !important;
    }
    .gate-form {
      display: flex;
      flex-direction: column;
      gap: 16px;
      align-items: center;
    }
    .gate-form input {
      width: 100%;
      padding: 16px 24px;
      border-radius: var(--radius-pill);
      border: 1px solid var(--border-soft);
      font-size: 16px;
      font-family: var(--font-main);
      text-align: center;
      letter-spacing: 0.15em;
      outline: none;
      transition: border-color 0.2s;
    }
    .gate-form input:focus {
      border-color: var(--brand-green);
    }
    .gate-form button {
      width: 100%;
    }
    .gate-error {
      color: #c0392b !important;
      font-weight: 500;
      margin-top: 16px !important;
      font-size: 14px !important;
    }
  </style>

  <script define:vars={{ previewCode: siteConfig.previewPassword }}>
    // Check if already authenticated
    if (sessionStorage.getItem('nz-preview') === 'ok') {
      document.getElementById('password-gate')?.classList.add('hidden');
    }

    document.getElementById('gate-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = document.getElementById('gate-input');
      const error = document.getElementById('gate-error');
      if (input.value === previewCode) {
        sessionStorage.setItem('nz-preview', 'ok');
        document.getElementById('password-gate')?.classList.add('hidden');
      } else {
        error.style.display = 'block';
        input.value = '';
        input.focus();
      }
    });
  </script>
)}
